{
  "name": "polymarket-copy-trader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n worker,dashboard \"npm:worker\" \"npm:dashboard\"",
    "worker": "tsx src/worker.ts",
    "worker:once": "cross-env WORKER_RUN_ONCE=1 tsx src/worker.ts",
    "cycle:reset": "tsx src/resetCycle.ts",
    "dashboard": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@polymarket/clob-client-v2": "^1.0.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "pino": "^10.1.0",
    "tsx": "^4.20.6",
    "viem": "^2.39.3",
    "ws": "^8.18.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
